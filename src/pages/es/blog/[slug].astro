---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/index.ts';
import '../../../styles/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    data.lang === 'es' && !data.draft
  );
  return posts.map(post => ({ params: { slug: post.id.split('/').pop() }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = 'es';
const t = useTranslations(lang);
---
<BaseLayout title={`${post.data.title} — ${t.pageTitle}`} description={post.data.description} lang={lang}>
  <Header lang={lang} />
  <div class="container">
    <div class="header-spacer"></div>
    <article class="blog-post">
      <a href="/es/blog/" class="blog-post-back">
        <i class="fa-solid fa-arrow-left"></i> Back to Blog
      </a>
      <div class="blog-post-meta">
        <span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="blog-post-tags">
          {post.data.tags.map(tag => <span class="blog-post-tag">#{tag}</span>)}
        </div>
      )}
      <h1 class="blog-post-title">{post.data.title}</h1>
      <div class="blog-post-content">
        <Content />
      </div>
    </article>
    <Footer lang={lang} />
  </div>
</BaseLayout>
