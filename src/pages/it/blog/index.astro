---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/index.ts';
import '../../../styles/blog.css';

const lang = 'it';
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ data }) =>
  data.lang === lang && !data.draft
)).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title={`Blog — ${t.pageTitle}`} lang={lang}>
  <Header lang={lang} />
  <div class="container">
    <div class="header-spacer"></div>
    <section class="blog-section">
      <div class="blog-header">
        <p class="section-prompt">&gt; Blog</p>
        <h1 class="section-title">Articles & Insights</h1>
      </div>
      {posts.length === 0 ? (
        <p class="blog-empty">// No articles published yet. Check back soon.</p>
      ) : (
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/it/blog/${post.id.split('/').pop()}/`} class="blog-card reveal">
              <div class="blog-card-meta">
                <span class="blog-card-date">{post.data.pubDate.toISOString().slice(0, 10)}</span>
                {post.data.tags.length > 0 && (
                  <div class="blog-card-tags">
                    {post.data.tags.map(tag => <span class="blog-card-tag">#{tag}</span>)}
                  </div>
                )}
              </div>
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <span class="blog-card-cta">&gt; READ_MORE →</span>
            </a>
          ))}
        </div>
      )}
    </section>
    <Footer lang={lang} />
  </div>
</BaseLayout>
