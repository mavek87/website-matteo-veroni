---
import '../styles/io.css';
import { useTranslations } from '../i18n/index.ts';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section class="io-section">
  <h3 class="section-title"><span class="section-prompt">></span> {t.ioTitle}</h3>
  <div class="io-grid">
    <a href="https://www.linkedin.com/in/matteoveroni" class="io-item reveal-ping" target="_blank" rel="noopener" aria-label="LinkedIn profile — Matteo Veroni">
      <div class="io-icon"><i class="fa-brands fa-linkedin"></i></div>
      <div class="io-value">LinkedIn</div>
      <div class="io-handle">in/matteoveroni</div>
    </a>
    <a href="https://github.com/mavek87" class="io-item reveal-ping" style="--ad: 0.12s;" target="_blank" rel="noopener" aria-label="GitHub profile — mavek87">
      <div class="io-icon"><i class="fa-brands fa-github"></i></div>
      <div class="io-value">GitHub</div>
      <div class="io-handle">@mavek87</div>
    </a>
    <a href="https://www.youtube.com/@MatteoVeroni" class="io-item reveal-ping" style="--ad: 0.24s;" target="_blank" rel="noopener" aria-label="YouTube channel — Matteo Veroni">
      <div class="io-icon"><i class="fa-brands fa-youtube"></i></div>
      <div class="io-value">YouTube</div>
      <div class="io-handle">@MatteoVeroni</div>
    </a>
    <a href="mailto:matver87@gmail.com" class="io-item reveal-ping" style="--ad: 0.36s;" aria-label="Email — matver87@gmail.com">
      <div class="io-icon"><i class="fa-solid fa-envelope"></i></div>
      <div class="io-value">Email</div>
      <div class="io-handle">matver87@gmail.com</div>
    </a>
  </div>
</section>
