---
import '../styles/services.css';
import ServiceCard from './ServiceCard.astro';
import { useTranslations } from '../i18n/index.ts';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const cards = [
  {
    label: t.card1Label,
    title: t.card1Title,
    description: t.card1Desc,
    tags: [t.card1Tag1, t.card1Tag2, t.card1Tag3],
    colorVar: '--c1',
    ctaText: t.cardCta,
    iconSvg: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  },
  {
    label: t.card2Label,
    title: t.card2Title,
    description: t.card2Desc,
    tags: [t.card2Tag1, t.card2Tag2, t.card2Tag3],
    colorVar: '--c2',
    ctaText: t.cardCta,
    revealDelay: '0.1s',
    iconSvg: '<polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/>',
  },
  {
    label: t.card3Label,
    title: t.card3Title,
    description: t.card3Desc,
    tags: [t.card3Tag1, t.card3Tag2, t.card3Tag3, t.card3Tag4],
    colorVar: '--c3',
    ctaText: t.cardCta,
    revealDelay: '0.1s',
    iconSvg: '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
  },
  {
    label: t.card4Label,
    title: t.card4Title,
    description: t.card4Desc,
    tags: [t.card4Tag1, t.card4Tag2, t.card4Tag3],
    colorVar: '--c4',
    ctaText: t.cardCta,
    revealDelay: '0.2s',
    iconSvg: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
];
---

<section id="services">
  <h3 class="section-title" style="margin-bottom: 30px;">
    <span class="section-prompt">></span> {t.servicesTitle}
  </h3>
  <div class="services-grid">
    {cards.map(card => <ServiceCard {...card} />)}
  </div>
</section>

<script>
  document.querySelectorAll('.card').forEach((card, idx) => {
    setTimeout(() => card.classList.add('loaded'), 200 + idx * 180);
  });
</script>
