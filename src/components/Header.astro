---
import '../styles/header.css';
import { useTranslations } from '../i18n/index.ts';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const locales = ['de', 'en', 'es', 'fr', 'it'];
---

<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <a href={`/${lang}/`} class="header-logo" aria-label="Home">
      <span style="color:#00e5ff;">></span>
      <span id="logo-text"></span><span class="cursor" id="logo-cursor" style="visibility:hidden;">_</span>
    </a>
    <div class="header-right">
      <nav class="header-nav" aria-label="Site navigation">
        <a href={`/${lang}/#services`} class="nav-link">{t.navServices}</a>
        <a href={`/${lang}/#about`} class="nav-link">{t.navAbout}</a>
        <a href={`/${lang}/#contacts`} class="nav-link">{t.navContact}</a>
        <a href={`/${lang}/blog/`} class="nav-link">{t.navBlog}</a>
      </nav>
      <div class="lang-dropdown" id="langDropdown" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language" tabindex="0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <span class="lang-label" id="langLabel">{lang.toUpperCase()}</span>
        <span class="lang-caret">▾</span>
        <ul class="lang-options" role="listbox" id="langOptions">
          {locales.map(l => (
            <li class={`lang-option${l === lang ? ' selected' : ''}`} role="option" aria-selected={l === lang} data-value={l}>
              {l === lang ? <span class="lang-option-arrow">&gt;</span> : <span class="lang-option-arrow"> </span>}
              {l.toUpperCase()}
            </li>
          ))}
        </ul>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
  <a href={`/${lang}/#services`} class="nav-link">{t.navServices}</a>
  <a href={`/${lang}/#about`} class="nav-link">{t.navAbout}</a>
  <a href={`/${lang}/#contacts`} class="nav-link">{t.navContact}</a>
  <a href={`/${lang}/blog/`} class="nav-link">{t.navBlog}</a>
  <div class="lang-dropdown" id="langDropdownMobile" role="combobox" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language" tabindex="0">
    <i class="fa-solid fa-globe"></i>
    <span class="lang-label" id="langLabelMobile">{lang.toUpperCase()}</span>
    <span class="lang-caret">▾</span>
    <ul class="lang-options" role="listbox" id="langOptionsMobile">
      {locales.map(l => (
        <li class={`lang-option${l === lang ? ' selected' : ''}`} role="option" aria-selected={l === lang} data-value={l}>
          {l === lang ? <span class="lang-option-arrow">&gt;</span> : <span class="lang-option-arrow"> </span>}
          {l.toUpperCase()}
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  // Logo typewriter
  (function () {
    const full = 'MATTEO_VERONI';
    const textEl = document.getElementById('logo-text');
    const cursorEl = document.getElementById('logo-cursor');
    let i = 0;
    function type() {
      if (i < full.length) { textEl!.textContent += full[i++]; setTimeout(type, 90); }
      else { (cursorEl as HTMLElement).style.visibility = 'visible'; }
    }
    setTimeout(type, 300);
  })();

  // Sticky scroll class
  const siteHeader = document.getElementById('siteHeader');
  window.addEventListener('scroll', () => {
    siteHeader!.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Hamburger toggle
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobileNav')!;
  hamburger.addEventListener('click', () => {
    const isOpen = mobileNav.classList.toggle('open');
    hamburger.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });
  mobileNav.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
    });
  });

  // Smooth scrolling for anchor links
  function smoothScrollTo(targetY: number) {
    const start = window.scrollY;
    const distance = targetY - start;
    const duration = Math.min(800, Math.max(400, Math.abs(distance) * 0.5));
    const startTime = performance.now();
    function easeInOutCubic(t: number) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }
    function step(now: number) {
      const progress = Math.min((now - startTime) / duration, 1);
      window.scrollTo(0, start + distance * easeInOutCubic(progress));
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  document.querySelectorAll<HTMLAnchorElement>('a[href*="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      const href = this.getAttribute('href');
      if (!href) return;
      const hashIndex = href.indexOf('#');
      if (hashIndex === -1) return;
      const hash = href.slice(hashIndex + 1);
      const path = href.slice(0, hashIndex).replace(/\/$/, '');
      const currentPath = window.location.pathname.replace(/\/$/, '');
      if (!hash || (path !== '' && path !== currentPath)) return;
      const target = document.getElementById(hash);
      if (target) {
        e.preventDefault();
        history.pushState(null, '', `#${hash}`);
        const headerH = (document.getElementById('siteHeader')?.offsetHeight ?? 0);
        smoothScrollTo(target.getBoundingClientRect().top + window.scrollY - headerH);
      }
    });
  });

  // Language switcher — custom dropdown
  function onLangChange(locale: string) {
    document.cookie = `preferred_lang=${locale}; max-age=${60 * 60 * 24 * 365}; path=/; SameSite=Lax`;
    window.location.href = `/${locale}/`;
  }

  function setupDropdown(dropdownId: string, labelId: string) {
    const dropdown = document.getElementById(dropdownId)!;
    const label = document.getElementById(labelId)!;
    const options = dropdown.querySelectorAll<HTMLElement>('.lang-option');

    function toggleOpen(force?: boolean) {
      const isOpen = force !== undefined ? force : dropdown.getAttribute('aria-expanded') !== 'true';
      dropdown.setAttribute('aria-expanded', String(isOpen));
    }

    dropdown.addEventListener('click', (e) => {
      e.stopPropagation();
      const option = (e.target as HTMLElement).closest<HTMLElement>('.lang-option');
      if (option) {
        const val = option.dataset.value!;
        label.textContent = val.toUpperCase();
        options.forEach(o => {
          const arrow = o.querySelector('.lang-option-arrow')!;
          const isSelected = o.dataset.value === val;
          o.classList.toggle('selected', isSelected);
          o.setAttribute('aria-selected', String(isSelected));
          arrow.textContent = isSelected ? '>' : ' ';
        });
        toggleOpen(false);
        onLangChange(val);
      } else {
        toggleOpen();
      }
    });

    dropdown.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleOpen(); }
      if (e.key === 'Escape') toggleOpen(false);
    });
  }

  setupDropdown('langDropdown', 'langLabel');
  setupDropdown('langDropdownMobile', 'langLabelMobile');

  document.addEventListener('click', () => {
    document.getElementById('langDropdown')!.setAttribute('aria-expanded', 'false');
    document.getElementById('langDropdownMobile')!.setAttribute('aria-expanded', 'false');
  });
</script>
