---
import '../styles/global.css';
import BackToTop from '../components/BackToTop.astro';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/jetbrains-mono/800.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fortawesome/fontawesome-free/css/all.min.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Matteo Veroni | Software Architect & Engineer',
  description = 'Software Architect, Fullstack Developer and AI & DevOps Engineer with 10+ years experience. I build systems that evolve with you',
  lang = 'en'
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon-mv.svg" />
  </head>
  <body>
    <slot />
    <BackToTop />
    <script>
      import '../scripts/scroll-reveal.ts';
    </script>
  </body>
</html>
