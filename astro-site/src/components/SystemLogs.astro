---
import '../styles/logs.css';
---

<section class="logs-section reveal">
  <h3><span class="section-prompt">></span> System_Logs</h3>
  <div class="log-container" id="logBox"></div>
</section>

<script>
  const logs = [
    "Initializing core modules...",
    "Establishing secure connection to AWS-region-1...",
    "Database migration [SHARD_01] complete. Zero downtime.",
    "CI/CD pipeline deployed: release cycle reduced by 50%.",
    "EventBus throughput optimized: 1.2M req/sec.",
    "AI Agent 'UFO' deployed to production cluster.",
    "Scaling infra: 4200 concurrent users — nominal.",
    "System health: 99.99% uptime maintained.",
    "Mentorship session committed. 3 devs leveled up.",
    "Secure handshake with client environment established."
  ];

  const logBox = document.getElementById('logBox')!;

  function addLog() {
    const now = new Date().toLocaleTimeString();
    const msg = logs[Math.floor(Math.random() * logs.length)];
    const div = document.createElement('div');
    div.className = 'log-line';
    div.innerHTML = `<span class="ts">[${now}]</span><span class="lvl">INFO</span><span class="msg">${msg}</span>`;
    logBox.prepend(div);
    if (logBox.children.length > 15) logBox.lastChild!.remove();
  }

  setInterval(addLog, 2800);
  addLog();
</script>
