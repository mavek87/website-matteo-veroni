---
import '../styles/services.css';
import ServiceCard from './ServiceCard.astro';

const cards = [
  {
    label: '[ARCH]',
    title: 'Architecture & Consulting',
    description: "Before you build, make sure you're building the right thing. I review, design, and validate system architectures. What you ship today should still make sense in two years.",
    tags: ['#System Design', '#Cloud', '#Infrastructure'],
    colorVar: '--c1',
    iconSvg: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  },
  {
    label: '[BUILD]',
    title: 'Software Development',
    description: "New features, legacy rescue, or full systems from scratch. Clean, maintainable code your team can read, extend, and own. The kind that makes the next engineer's life easier, not harder.",
    tags: ['#Develop', '#Refactoring', '#Legacy Rescue'],
    colorVar: '--c2',
    revealDelay: '0.1s',
    iconSvg: '<polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/>',
  },
  {
    label: '[AUTO]',
    title: 'AI & DevOps Automation',
    description: "Repetitive tasks, slow deployments, manual workflows — I automate what slows you down. From CI/CD pipelines to AI agents that keep delivering after you log off.",
    tags: ['#DevOps', '#CI/CD', '#LLM', '#Agents'],
    colorVar: '--c3',
    revealDelay: '0.1s',
    iconSvg: '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
  },
  {
    label: '[EDU]',
    title: 'Mentorship & Training',
    description: "For developers who want to level up and teams that want to ship better. 1-on-1 sessions or group training — backend, DevOps, modern architectures.",
    tags: ['#Mentorship', '#Training', '#Online'],
    colorVar: '--c4',
    revealDelay: '0.2s',
    iconSvg: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
];
---

<section id="services">
  <h3 class="section-title" style="margin-bottom: 30px;">
    <span class="section-prompt">></span> Services
  </h3>
  <div class="services-grid">
    {cards.map(card => <ServiceCard {...card} />)}
  </div>
</section>

<script>
  document.querySelectorAll('.card').forEach((card, idx) => {
    setTimeout(() => card.classList.add('loaded'), 200 + idx * 180);
  });
</script>
