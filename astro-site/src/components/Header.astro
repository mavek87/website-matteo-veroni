---
import '../styles/header.css';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const locales = ['de', 'en', 'es', 'fr', 'it'];
---

<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <div class="header-logo">
      <span style="color:#00e5ff;">></span>
      <span id="logo-text"></span><span class="cursor" id="logo-cursor" style="visibility:hidden;">_</span>
    </div>
    <div class="header-right">
      <nav class="header-nav" aria-label="Site navigation">
        <a href="#services" class="nav-link">Services</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#blog" class="nav-link">Blog</a>
      </nav>
      <div class="lang-select-wrapper" title="Change language">
        <i class="fa-solid fa-globe"></i>
        <span class="lang-label" id="langLabel">{lang.toUpperCase()}</span>
        <span class="lang-caret">▾</span>
        <select class="lang-select" id="langSelect" aria-label="Select language">
          {locales.map(l => (
            <option value={l} selected={l === lang}>{l.toUpperCase()}</option>
          ))}
        </select>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
  <a href="#services" class="nav-link">Services</a>
  <a href="#about" class="nav-link">About</a>
  <a href="#blog" class="nav-link">Blog</a>
  <div class="lang-select-wrapper" title="Change language">
    <i class="fa-solid fa-globe"></i>
    <span class="lang-label" id="langLabelMobile">{lang.toUpperCase()}</span>
    <span class="lang-caret">▾</span>
    <select class="lang-select" id="langSelectMobile" aria-label="Select language">
      {locales.map(l => (
        <option value={l} selected={l === lang}>{l.toUpperCase()}</option>
      ))}
    </select>
  </div>
</nav>

<script>
  // Logo typewriter
  (function () {
    const full = 'MATTEO_VERONI';
    const textEl = document.getElementById('logo-text');
    const cursorEl = document.getElementById('logo-cursor');
    let i = 0;
    function type() {
      if (i < full.length) { textEl!.textContent += full[i++]; setTimeout(type, 90); }
      else { (cursorEl as HTMLElement).style.visibility = 'visible'; }
    }
    setTimeout(type, 300);
  })();

  // Sticky scroll class
  const siteHeader = document.getElementById('siteHeader');
  window.addEventListener('scroll', () => {
    siteHeader!.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Hamburger toggle
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobileNav')!;
  hamburger.addEventListener('click', () => {
    const isOpen = mobileNav.classList.toggle('open');
    hamburger.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });
  mobileNav.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
    });
  });

  // Language switcher — cookie + navigation
  function onLangChange(locale: string) {
    document.cookie = `preferred_lang=${locale}; max-age=${60 * 60 * 24 * 365}; path=/; SameSite=Lax`;
    window.location.href = `/${locale}/`;
  }

  const langSelect = document.getElementById('langSelect') as HTMLSelectElement;
  const langLabel = document.getElementById('langLabel')!;
  const langSelectMobile = document.getElementById('langSelectMobile') as HTMLSelectElement;
  const langLabelMobile = document.getElementById('langLabelMobile')!;

  langSelect.addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    langLabel.textContent = val.toUpperCase();
    langLabelMobile.textContent = val.toUpperCase();
    langSelectMobile.value = val;
    onLangChange(val);
  });
  langSelectMobile.addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    langLabel.textContent = val.toUpperCase();
    langLabelMobile.textContent = val.toUpperCase();
    langSelect.value = val;
    onLangChange(val);
  });
</script>
